# ==========================================
# Pingback — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
#
# For a production/EC2 deploy, see deploy/.env.example for the runtime
# values the systemd service reads from /opt/pingback/.env.

# --- Core ---
APP_ENV=development
PORT=8000
HOST=0.0.0.0
DB_PATH=pingback.db
APP_BASE_URL=http://localhost:8000

# Encryption key for sensitive fields (Fernet symmetric encryption).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Data retention
RETENTION_DAYS=90
ABANDONED_ACCOUNT_DAYS=30

# --- Email (Resend — https://resend.com) ---
# RESEND_FROM_EMAIL is the legacy single-sender fallback. Prefer the split
# identities below so digest mail and account mail keep separate reputations.
# `hello@` is reserved for human-to-human replies — do not use it here.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Pingback <noreply@example.com>
EMAIL_FROM_DIGEST=Pingback Digest <digest@usepingback.com>
EMAIL_FROM_NOREPLY=Pingback <noreply@usepingback.com>

# --- AWS (optional; required only for SES + CloudWatch log shipping) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# AWS_REGION=us-east-1            # used by docker-compose.aws.yml log driver
# AWS_LOG_GROUP=pingback

# --- Stripe billing (optional; leave blank to disable paid tiers) ---
# Test mode: sk_test_... / pk_test_... from Dashboard → Developers → API keys.
# Webhook secret (whsec_...): Dashboard → Developers → Webhooks signing secret,
# or printed once by `stripe listen --forward-to localhost:8000/api/stripe/webhook`.
# Price IDs: create a recurring product in Stripe and copy its price_... id.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_ANNUAL=
# Legacy alias — used as the fallback when STRIPE_PRICE_ID_PRO_MONTHLY is blank.
STRIPE_PRO_PRICE_ID=

# --- Sentry error tracking (optional; leave SENTRY_DSN blank to disable) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Enables /debug/boom for verifying Sentry end-to-end. Never enable in prod.
DEBUG_BOOM_ENABLED=

# --- HTTPS provisioning (consumed by deploy/enable-https.sh on the EC2 host) ---
# DOMAIN=example.com
# CERTBOT_EMAIL=ops@example.com
