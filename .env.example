# ==========================================
# Pingback — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
#
# For a production/EC2 deploy, see deploy/.env.example for the runtime
# values the systemd service reads from /opt/pingback/.env.

# --- Core ---
APP_ENV=development
PORT=8000
HOST=0.0.0.0
DB_PATH=pingback.db
APP_BASE_URL=http://localhost:8000

# Encryption key for sensitive fields (Fernet symmetric encryption).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Data retention — operator ceiling. Per-plan windows (Free 7d, Pro 90d,
# Business 1yr) are bounded by this value, so keep it >= the highest plan.
RETENTION_DAYS=365
ABANDONED_ACCOUNT_DAYS=30

# --- Email (Resend — https://resend.com) ---
# RESEND_FROM_EMAIL is the legacy single-sender fallback. Prefer the split
# identities below so daily-status mail and account mail keep separate
# reputations. `hello@` is inbound-only (forwarded via Namecheap) — do not
# use it as an outbound sender.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Pingback <noreply@example.com>
EMAIL_FROM_DAILY_STATUS=Pingback Daily Status <daily_status@usepingback.com>
EMAIL_FROM_NOREPLY=Pingback <noreply@usepingback.com>

# --- AWS (optional; required for SES, CloudWatch log shipping, and S3 backup
# off-box copy) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# AWS_REGION=us-east-1            # used by docker-compose.aws.yml log driver
# AWS_LOG_GROUP=pingback

# --- DB backup off-box copy (MAK-145; optional) ---
# When BACKUP_S3_BUCKET is set, deploy/backup-db.sh uploads each nightly
# archive (.db.gz + .sha256) to s3://$BACKUP_S3_BUCKET/$BACKUP_S3_PREFIX/.
# Failure is non-fatal; the local copy stays canonical. Requires the AWS_*
# vars above with at least s3:PutObject + s3:ListBucket on the bucket.
# BACKUP_S3_BUCKET=pingback-backups-prod
# BACKUP_S3_PREFIX=backups/daily

# --- Paddle billing (optional; leave blank to disable paid tiers) ---
# PADDLE_ENVIRONMENT=sandbox uses sandbox-vendors.paddle.com; production hits
# vendors.paddle.com. Webhook URL to register: /api/paddle/webhook.
# Events: subscription.{created,updated,canceled}, transaction.{completed,payment_failed}
PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRODUCT_ID=
PADDLE_PRICE_ID_MONTHLY=
PADDLE_PRICE_ID_YEARLY=
PADDLE_DISCOUNT_ID_LAUNCH=

# --- Sentry error tracking (optional; leave SENTRY_DSN blank to disable) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Enables /debug/boom for verifying Sentry end-to-end. Never enable in prod.
DEBUG_BOOM_ENABLED=

# --- Admin dashboard (MAK-142) ---
# Comma-separated emails granted access to /admin. Leave blank to fully close
# the route (every request 404s). Compared case-insensitively against the
# logged-in session email.
# ADMIN_EMAILS=ops@usepingback.com
# Optional: link out from /admin's errors panel to your Sentry project view.
# SENTRY_DASHBOARD_URL=https://sentry.io/organizations/your-org/projects/pingback/

# --- HTTPS provisioning (consumed by deploy/enable-https.sh on the EC2 host) ---
# DOMAIN=example.com
# CERTBOT_EMAIL=ops@example.com
