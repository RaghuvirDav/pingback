# ==========================================
# Pingback — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
#
# For a production/EC2 deploy, see deploy/.env.example for the runtime
# values the systemd service reads from /opt/pingback/.env.

# --- Core ---
APP_ENV=development
PORT=8000
HOST=0.0.0.0
DB_PATH=pingback.db
APP_BASE_URL=http://localhost:8000

# Encryption key for sensitive fields (Fernet symmetric encryption).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Data retention
RETENTION_DAYS=90
ABANDONED_ACCOUNT_DAYS=30

# --- Email (Resend — https://resend.com) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Pingback <noreply@example.com>

# --- AWS (optional; required only for SES + CloudWatch log shipping) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# AWS_REGION=us-east-1            # used by docker-compose.aws.yml log driver
# AWS_LOG_GROUP=pingback

# --- Paddle billing (optional; leave blank to disable paid tiers) ---
# PADDLE_ENV: sandbox for testing, production once the vendor account is live.
# PADDLE_CLIENT_SIDE_TOKEN: Paddle Dashboard → Developer Tools → Authentication
#   → Client-side Token (prefix `live_` or `test_`). Rendered into Paddle.js.
# PADDLE_API_KEY: server key — prefix `pdl_live_apikey_` or `pdl_sdbx_apikey_`.
# PADDLE_NOTIFICATION_SECRET: Paddle Dashboard → Developer Tools → Notifications
#   → your endpoint → "Secret key" (prefix `pdl_ntfset_`). Signs the webhooks.
# PADDLE_PRICE_ID_*: Catalog → Pingback Pro → price ids (prefix `pri_`).
PADDLE_ENV=sandbox
PADDLE_API_KEY=
PADDLE_CLIENT_SIDE_TOKEN=
PADDLE_NOTIFICATION_SECRET=
PADDLE_PRICE_ID_PRO_MONTHLY=
PADDLE_PRICE_ID_PRO_ANNUAL=

# --- Sentry error tracking (optional; leave SENTRY_DSN blank to disable) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Enables /debug/boom for verifying Sentry end-to-end. Never enable in prod.
DEBUG_BOOM_ENABLED=

# --- HTTPS provisioning (consumed by deploy/enable-https.sh on the EC2 host) ---
# DOMAIN=example.com
# CERTBOT_EMAIL=ops@example.com
