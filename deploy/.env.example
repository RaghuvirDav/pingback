# Pingback Environment Configuration
# Copy to /opt/pingback/.env and fill in values

# App environment — set to "production" to enforce HTTPS redirect
APP_ENV=production

# Base URL for email links
APP_BASE_URL=https://usepingback.com

# Database path (on EBS volume for persistence)
DB_PATH=/opt/pingback/data/pingback.db

# Encryption key for sensitive fields (generate with):
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Resend API key for transactional emails
RESEND_API_KEY=

# Sender address (must match verified domain in Resend)
RESEND_FROM_EMAIL=Pingback <noreply@usepingback.com>

# Data retention (days)
RETENTION_DAYS=90

# Abandoned account threshold (days)
ABANDONED_ACCOUNT_DAYS=30
