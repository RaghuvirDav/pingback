# Pingback Environment Configuration (production deploy target)
# Copy to /opt/pingback/.env and fill in values. This file is the operator-owned
# runtime config read by systemd/pingback.service on the EC2 host.

# App environment — set to "production" to enforce HTTPS redirect
APP_ENV=production

# Base URL for email links and self-references. Must match the HTTPS domain
# you serve from (see deploy/enable-https.sh).
APP_BASE_URL=https://example.com

# Database path (on EBS volume for persistence)
DB_PATH=/opt/pingback/data/pingback.db

# Encryption key for sensitive fields. Generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Resend API key for transactional emails (https://resend.com)
RESEND_API_KEY=

# Sender address — must match a verified domain in Resend
RESEND_FROM_EMAIL=Pingback <noreply@example.com>

# Data retention ceiling (days). Per-plan windows are bounded by this; keep
# >= 365 so Business's 1-year history is not silently truncated.
RETENTION_DAYS=365

# Abandoned account threshold (days)
ABANDONED_ACCOUNT_DAYS=30

# --- Optional: Sentry error tracking (https://sentry.io) ---
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=

# --- Optional: Paddle billing (https://paddle.com) ---
# Webhook URL to register: https://your-domain.com/api/paddle/webhook
# Events: subscription.{created,updated,canceled}, transaction.{completed,payment_failed}
# Set PADDLE_ENVIRONMENT=production for the live vendor account; sandbox for dev.
# PADDLE_ENVIRONMENT=production
# PADDLE_API_KEY=
# PADDLE_CLIENT_TOKEN=
# PADDLE_WEBHOOK_SECRET=
# PADDLE_PRODUCT_ID=
# PADDLE_PRICE_ID_MONTHLY=
# PADDLE_PRICE_ID_YEARLY=
# PADDLE_DISCOUNT_ID_LAUNCH=

# --- Optional: AWS CloudWatch log shipping (used by docker-compose.aws.yml) ---
# AWS_REGION=us-east-1
# AWS_LOG_GROUP=pingback
